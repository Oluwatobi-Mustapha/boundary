#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so running from ~/.local/bin/boundary still finds repo/src.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
exec python3 "${SCRIPT_DIR}/src/boundary_cli.py" "$@"
